DEMO_MODE=false
MAX_COMPETITORS_PER_SCAN=4
MAX_CUSTOMERS_PER_COMPETITOR=5
DATA_PATH=.data/displacement-agent.json
SEED_DATA_PATH=app/demo_snapshot.json

# Required for real Apollo account/contact lookup.
APOLLO_API_KEY=

# Optional: OpenAI-based web-search prospecting for competitor customers.
# If set, clicking "Find impacted customers" will use OpenAI web search to find
# likely customer accounts (no Apollo required).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional but recommended for Claude + Apollo MCP prospecting and company discovery.
CLAUDE_MCP_CONFIG=
CLAUDE_MAX_BUDGET_USD=0.25
CLAUDE_TIMEOUT_SECONDS=45

# If true, prefer Claude CLI + Apollo MCP for "Find impacted customers"
# (closest behavior to the standalone displacement.html demo).
PREFER_CLAUDE_MCP_PROSPECTING=false

# Optional: let Claude draft emails instead of the deterministic fallback.
CLAUDE_DRAFT_EMAILS=false

# Optional: Vertex grounding for live competitor signal discovery.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash
