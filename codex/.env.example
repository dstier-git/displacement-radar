DEMO_MODE=false
MAX_COMPETITORS_PER_SCAN=4
MAX_CUSTOMERS_PER_COMPETITOR=5

# Required for real Apollo account/contact lookup.
APOLLO_API_KEY=

# Optional but recommended for Claude + Apollo MCP prospecting and company discovery.
CLAUDE_MCP_CONFIG=
CLAUDE_MAX_BUDGET_USD=0.25
CLAUDE_TIMEOUT_SECONDS=45

# Optional: let Claude draft emails instead of the deterministic fallback.
CLAUDE_DRAFT_EMAILS=false

# Optional: Vertex grounding for live competitor signal discovery.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash
